# ── Infrastructure ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@localhost:5432/wiredhowse_magic_link
REDIS_URL=redis://localhost:6379

# ── Resend (email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Must match the verified sending domain in Resend
RESEND_FROM=no-reply@magic-link.wiredhowse.app

# ── API service ───────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=info
# Public URL of this API service (used in email links)
SITE_URL=https://magic-link.wiredhowse.app

# ── Web / dashboard service ───────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Safety valves ─────────────────────────────────────────────────────────────
# Setting this crashes the API at boot in NODE_ENV=production (intentional).
# Only usable in development/test.
# WH_DISABLE_RATE_LIMITS=1
