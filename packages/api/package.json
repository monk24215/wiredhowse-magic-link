{
  "name": "@wiredhowse/api",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:cron": "tsx watch src/cron.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:cron": "node dist/cron.js",
    "run-once": "tsx src/cron-run-once.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:integration": "vitest run --config vitest.integration.config.ts --passWithNoTests"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.0",
    "@node-rs/argon2": "^2.0.2",
    "@wiredhowse/db": "workspace:*",
    "@wiredhowse/shared": "workspace:*",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.1",
    "node-cron": "^3.0.3",
    "resend": "^4.0.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/node-cron": "^3.0.11",
    "@wiredhowse/snippet": "workspace:*",
    "pino-pretty": "^13.0.0",
    "testcontainers": "^10.0.0",
    "vitest": "^2.1.8"
  }
}
